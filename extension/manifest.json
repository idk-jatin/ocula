{
  "manifest_version": 3,
  "name": "OCULA",
  "version": "1.0.0",
  "description": "Multilingual hate speech detection. See the hate. Understand why.",

  "permissions": ["storage", "activeTab"],

  "host_permissions": [
    "https://twitter.com/*",
    "https://x.com/*",
    "https://www.youtube.com/*",
    "https://www.reddit.com/*",
    "https://www.facebook.com/*",
    "http://*/*",
    "https://*/*"
  ],

  "background": {
    "service_worker": "background/service_worker.js",
    "type": "module"
  },

  "content_scripts": [
    {
      "matches": ["https://twitter.com/*", "https://x.com/*"],
      "js": ["shared/overlay.js", "content/twitter.js"],
      "css": ["shared/styles.css"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://www.youtube.com/*"],
      "js": ["shared/overlay.js", "content/youtube.js"],
      "css": ["shared/styles.css"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://www.reddit.com/*"],
      "js": ["shared/overlay.js", "content/reddit.js"],
      "css": ["shared/styles.css"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://www.facebook.com/*"],
      "js": ["shared/overlay.js", "content/facebook.js"],
      "css": ["shared/styles.css"],
      "run_at": "document_idle"
    }
  ],

  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "OCULA",
    "default_icon": {
      "16":  "icons/icon16.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}